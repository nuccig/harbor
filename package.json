{
  "name": "harbor",
  "version": "0.0.0",
  "description": "Harbor — local-first desktop app for coding agents",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:app": "electron-builder",
    "app": "electron .",
    "postinstall": "node scripts/patch-node-pty.cjs && electron-rebuild"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@phosphor-icons/react": "^2.1.10",
    "better-sqlite3": "^11.7.0",
    "drizzle-orm": "^0.38.3",
    "electron-updater": "^6.3.9",
    "iconoir-react": "^7.11.1",
    "keytar": "^7.9.0",
    "motion": "^12.42.2",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shaders": "^2.5.135"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.16.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.harbor.app",
    "productName": "Harbor",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
